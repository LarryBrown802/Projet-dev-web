{# On hérite du squelette principal #}
{% extends 'base.html.twig' %}

{# Titre de la page #}
{% block title %}LEMS - Tableau de bord Admin{% endblock %}

{# CSS spécifique au dashboard admin #}
{% block stylesheets %}
    <link rel="stylesheet" href="/assets/pages/admin.css">
{% endblock %}

{# Contenu principal #}
{% block content %}
    <main class="container">

        <div class="page-head">
            <div>
                <h1>Tableau de bord Admin</h1>
                <p class="page-subtitle">Vue d'ensemble globale de la plateforme LEMS.</p>
            </div>
            <div class="page-meta">
                <div class="meta-card">
                    <span class="meta-label">Rôle</span>
                    <span class="meta-value" style="font-size:15px">Administrateur</span>
                </div>
                <a href="/deconnexion" class="btn-danger" style="display:flex; align-items:center; text-decoration:none;">Déconnexion</a>
            </div>
        </div>

        <section class="kpi-grid kpi-grid--5">
            <article class="kpi-card">
                <div class="kpi-icon kpi-blue"><i class="fa-solid fa-chalkboard-teacher"></i></div>
                <div><p class="kpi-label">Pilotes</p><p class="kpi-value">8</p></div>
            </article>
            <article class="kpi-card">
                <div class="kpi-icon kpi-green"><i class="fa-solid fa-user-graduate"></i></div>
                <div><p class="kpi-label">Étudiants</p><p class="kpi-value">192</p></div>
            </article>
            <article class="kpi-card">
                <div class="kpi-icon kpi-yellow"><i class="fa-solid fa-building"></i></div>
                <div><p class="kpi-label">Entreprises</p><p class="kpi-value">34</p></div>
            </article>
            <article class="kpi-card">
                <div class="kpi-icon kpi-purple"><i class="fa-solid fa-briefcase"></i></div>
                <div><p class="kpi-label">Offres</p><p class="kpi-value">87</p></div>
            </article>
            <article class="kpi-card">
                <div class="kpi-icon kpi-red"><i class="fa-solid fa-file-circle-check"></i></div>
                <div><p class="kpi-label">Candidatures</p><p class="kpi-value">413</p></div>
            </article>
        </section>

        <div class="admin-layout">

            <aside class="admin-aside">
                <h2 class="section-title-dash">Activité récente</h2>
                <div class="activity-list">

                    <article class="activity-item">
                        <div class="activity-icon ai-blue"><i class="fa-solid fa-user-plus"></i></div>
                        <div class="activity-body">
                            <p class="activity-title">Nouvel étudiant inscrit</p>
                            <p class="activity-sub">Raphaël Linard - CPI A2 Informatique</p>
                            <span class="activity-time">Il y a 10 min</span>
                        </div>
                    </article>

                    <article class="activity-item">
                        <div class="activity-icon ai-yellow"><i class="fa-solid fa-briefcase"></i></div>
                        <div class="activity-body">
                            <p class="activity-title">Nouvelle offre publiée</p>
                            <p class="activity-sub">Dev Web — Tech Solutions</p>
                            <span class="activity-time">Il y a 35 min</span>
                        </div>
                    </article>

                    <article class="activity-item">
                        <div class="activity-icon ai-green"><i class="fa-solid fa-building"></i></div>
                        <div class="activity-body">
                            <p class="activity-title">Entreprise ajoutée</p>
                            <p class="activity-sub">AI Labs</p>
                            <span class="activity-time">Il y a 1h</span>
                        </div>
                    </article>

                    <article class="activity-item">
                        <div class="activity-icon ai-purple"><i class="fa-solid fa-chalkboard-teacher"></i></div>
                        <div class="activity-body">
                            <p class="activity-title">Pilote créé</p>
                            <p class="activity-sub">M. Roussel — CPI A2 Informatique</p>
                            <span class="activity-time">Il y a 2h</span>
                        </div>
                    </article>

                    <article class="activity-item">
                        <div class="activity-icon ai-red"><i class="fa-solid fa-trash"></i></div>
                        <div class="activity-body">
                            <p class="activity-title">Offre supprimée</p>
                            <p class="activity-sub">Stage Marketing — MKT Corp</p>
                            <span class="activity-time">Il y a 3h</span>
                        </div>
                    </article>

                    <article class="activity-item">
                        <div class="activity-icon ai-blue"><i class="fa-solid fa-file-circle-check"></i></div>
                        <div class="activity-body">
                            <p class="activity-title">Candidature reçue</p>
                            <p class="activity-sub">Enzo Boucetta → DevOps</p>
                            <span class="activity-time">Il y a 4h</span>
                        </div>
                    </article>

                    <article class="activity-item">
                        <div class="activity-icon ai-yellow"><i class="fa-solid fa-star"></i></div>
                        <div class="activity-body">
                            <p class="activity-title">Entreprise évaluée</p>
                            <p class="activity-sub">SecureTech — 4/5 étoiles</p>
                            <span class="activity-time">Il y a 5h</span>
                        </div>
                    </article>

                </div>
            </aside>

            <section class="admin-main">

                <div class="section-head-row">
                    <h2 class="section-title-dash">Vue d'ensemble des offres</h2>
                    <a href="/admin/offres" class="link-see-all">Voir tout <i class="fa-solid fa-arrow-right"></i></a>
                </div>

                <div class="table-wrap">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Titre</th>
                                <th>Entreprise</th>
                                <th>Type</th>
                                <th>Niveau</th>
                                <th>Lieu</th>
                                <th>Rémun.</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>Développeur Web</strong></td>
                                <td>Tech Solutions</td>
                                <td><span class="tag-pill tag-stage">Stage</span></td>
                                <td><span class="tag-pill tag-bac">Bac+2/3</span></td>
                                <td><span class="tag-pill tag-lieu">Lyon</span></td>
                                <td>900 €</td>
                                <td><span class="badge badge--ok">Active</span></td>
                            </tr>
                            <tr>
                                <td><strong>Data Analyst</strong></td>
                                <td>Data Insights</td>
                                <td><span class="tag-pill tag-alt">Alternance</span></td>
                                <td><span class="tag-pill tag-bac">Bac+3</span></td>
                                <td><span class="tag-pill tag-lieu">Paris</span></td>
                                <td>1 200 €</td>
                                <td><span class="badge badge--ok">Active</span></td>
                            </tr>
                            <tr>
                                <td><strong>Spécialiste Cyber</strong></td>
                                <td>SecureTech</td>
                                <td><span class="tag-pill tag-stage">Stage</span></td>
                                <td><span class="tag-pill tag-bac">Bac+4/5</span></td>
                                <td><span class="tag-pill tag-lieu">Lille</span></td>
                                <td>1 100 €</td>
                                <td><span class="badge badge--wait">En pause</span></td>
                            </tr>
                            <tr>
                                <td><strong>Ingénieur DevOps</strong></td>
                                <td>Cloud Solutions</td>
                                <td><span class="tag-pill tag-stage">Stage</span></td>
                                <td><span class="tag-pill tag-bac">Bac+4/5</span></td>
                                <td><span class="tag-pill tag-lieu">Marseille</span></td>
                                <td>1 300 €</td>
                                <td><span class="badge badge--ok">Active</span></td>
                            </tr>
                            <tr>
                                <td><strong>Ingénieur IA</strong></td>
                                <td>AI Labs</td>
                                <td><span class="tag-pill tag-alt">Alternance</span></td>
                                <td><span class="tag-pill tag-bac">Bac+5</span></td>
                                <td><span class="tag-pill tag-lieu">Bordeaux</span></td>
                                <td>1 500 €</td>
                                <td><span class="badge badge--no">Expirée</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="section-head-row" style="margin-top:22px">
                    <h2 class="section-title-dash">Pilotes enregistrés</h2>
                    <a href="/admin/pilotes" class="link-see-all">Voir tout <i class="fa-solid fa-arrow-right"></i></a>
                </div>

                <div class="table-wrap">
                    <table class="dash-table">
                        <thead>
                            <tr><th>Nom</th><th>Prénom</th><th>Promotion</th><th>Étudiants</th></tr>
                        </thead>
                        <tbody>
                            <tr><td><strong>Roussel</strong></td><td>Antoine</td><td>CPI A2 Informatique</td><td>27</td></tr>
                            <tr><td><strong>Jeanne</strong></td><td>Benoît</td><td>CPI A2 Généraliste</td><td>24</td></tr>
                            <tr><td><strong>Tout</strong></td><td>Firas</td><td>CPI A2 BTP</td><td>24</td></tr>
                        </tbody>
                    </table>
                </div>

            </section>
        </div>

    </main>
{% endblock %}