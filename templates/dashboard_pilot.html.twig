{% extends 'base.html.twig' %}

{% block title %}Dashboard Pilote{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/pages/Pilote.css">
{% endblock %}

{% block content %}
<main class="container">

    <div class="page-head">
        <div>
            <h1>Tableau de bord</h1>
            <p class="page-subtitle">Bienvenue, <strong>M. Dupont</strong> — Pilote de promotion CPI A2 Informatique</p>
        </div>
        <div class="page-meta">
            <div class="meta-card">
                <span class="meta-label">Promotion</span>
                <span class="meta-value">CPI A2 Informatique</span>
            </div>
            <div class="meta-card">
                <span class="meta-label">Étudiants</span>
                <span class="meta-value">27</span>
            </div>
        </div>
    </div>

    <!-- KPIs -->
    <section class="kpi-grid" aria-label="Indicateurs clés">
        <article class="kpi-card">
            <div class="kpi-icon kpi-blue"><i class="fa-solid fa-file-circle-check"></i></div>
            <div>
                <p class="kpi-label">Candidatures totales</p>
                <p class="kpi-value">87</p>
            </div>
        </article>
        <article class="kpi-card">
            <div class="kpi-icon kpi-green"><i class="fa-solid fa-user-graduate"></i></div>
            <div>
                <p class="kpi-label">Étudiants ayant postulé</p>
                <p class="kpi-value">18</p>
            </div>
        </article>
        <article class="kpi-card">
            <div class="kpi-icon kpi-yellow"><i class="fa-solid fa-building"></i></div>
            <div>
                <p class="kpi-label">Entreprises partenaires</p>
                <p class="kpi-value">12</p>
            </div>
        </article>
        <article class="kpi-card">
            <div class="kpi-icon kpi-purple"><i class="fa-solid fa-briefcase"></i></div>
            <div>
                <p class="kpi-label">Offres disponibles</p>
                <p class="kpi-value">4</p>
            </div>
        </article>
    </section>

    <!-- Raccourcis -->
    <section class="dash-section">
        <h2 class="section-title-dash">Accès rapides</h2>
        <div class="shortcut-grid">
            <a href="DashboardPGEntreprise.html" class="shortcut-card">
                <div class="shortcut-icon"><i class="fa-solid fa-building"></i></div>
                <span>Gérer les entreprises</span>
            </a>
            <a href="DashboardPGOffre.html" class="shortcut-card">
                <div class="shortcut-icon"><i class="fa-solid fa-briefcase"></i></div>
                <span>Gérer les offres</span>
            </a>
            <a href="DashboardPGEtudiant.html" class="shortcut-card">
                <div class="shortcut-icon"><i class="fa-solid fa-user-graduate"></i></div>
                <span>Gérer les étudiants</span>
            </a>
        </div>
    </section>

    <!-- Dernières candidatures -->
    <section class="dash-section">
        <div class="section-head-row">
            <h2 class="section-title-dash">Dernières candidatures de ma promotion</h2>
            <a href="DashboardPGEtudiant.html" class="link-see-all">Voir tout <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        <div class="table-wrap">
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Étudiant</th>
                        <th>Offre</th>
                        <th>Entreprise</th>
                        <th>Date</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Enzo boucetta</strong></td>
                        <td>Développeur Web</td>
                        <td>Tech Solutions</td>
                        <td>20/02/2026</td>
                        <td><span class="badge badge--wait">En attente</span></td>
                    </tr>
                    <tr>
                        <td><strong>Julien Voltz</strong></td>
                        <td>Data Analyst</td>
                        <td>Data Insights</td>
                        <td>19/02/2026</td>
                        <td><span class="badge badge--ok">Accepté</span></td>
                    </tr>
                    <tr>
                        <td><strong>Michel Battoktok</strong></td>
                        <td>Cybersécurité</td>
                        <td>SecureTech</td>
                        <td>18/02/2026</td>
                        <td><span class="badge badge--no">Refusé</span></td>
                    </tr>
                    <tr>
                        <td><strong>Samuel Verel</strong></td>
                        <td>DevOps</td>
                        <td>Cloud Solutions</td>
                        <td>17/02/2026</td>
                        <td><span class="badge badge--wait">En attente</span></td>
                    </tr>
                    <tr>
                        <td><strong>Larry Brown</strong></td>
                        <td>Ingénieur IA</td>
                        <td>AI Labs</td>
                        <td>16/02/2026</td>
                        <td><span class="badge badge--wait">En attente</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

</main>
{% endblock %}