{% extends 'base.html.twig' %}

{% block title %}Erreur {{ code }}{% endblock %}

{% block stylesheets %}
    {# Tu pourras créer un CSS spécifique pour l'erreur plus tard si tu veux #}
    <style>
        .error-container {
            text-align: center;
            padding: 100px 20px;
            min-height: 50vh;
        }
        .error-code {
            font-size: 6rem;
            font-weight: 800;
            color: #E13434;
            margin-bottom: 20px;
        }
        .error-message {
            font-size: 1.5rem;
            margin-bottom: 30px;
        }
        .btn-home {
            background-color: #333;
            color: white;
            padding: 15px 30px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
        }
    </style>
{% endblock %}

{% block content %}
    <div class="error-container">
        <h1 class="error-code">{{ code }}</h1>
        
        <p class="error-message">{{ message }}</p>
        
        <a href="/" class="btn-home">Retour à l'accueil</a>
    </div>
{% endblock %}