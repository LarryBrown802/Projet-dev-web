<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {# CSS global #}
    <link rel="stylesheet" href="/assets/main.css">

    {# CSS spécifique à la page #}
    {% block stylesheets %}{% endblock %}

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <title>{% block title %}LEMS{% endblock %}</title>
</head>
<body>
    <!-- ===== HEADER / NAVBAR ===== -->
    <header>
        <nav class="navbar">
            <a class="navbar-brand" href="/index.php?page=accueil">LEMS</a>

            <div class="navbar-right">
                <a href="/index.php?page=accueil" class="{% if current_page == 'accueil' %}active{% endif %}">Accueil</a>
                <a href="/index.php?page=offres" class="{% if current_page == 'offres' %}active{% endif %}">Offres</a>
                <a href="/index.php?page=entreprise" class="{% if current_page == 'entreprise' %}active{% endif %}">Entreprise</a>
                <a href="/index.php?page=connexion" class="btn-connexion">Connexion</a>

                <div class="profile">
                    <a class="profile-btn" href="/index.php?page=profil" aria-label="Profil">
                        <i class="fa-solid fa-user"></i>
                    </a>

                    <div class="profile-menu" role="menu">
                        <a href="/index.php?page=profil" role="menuitem">Mon profil</a>
                        <a href="/index.php?page=parametres" role="menuitem">Paramètres</a>
                        <hr>
                        <a href="/index.php?page=deconnexion" role="menuitem" class="deco">Déconnexion</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main>
        {% block content %}{% endblock %}
    </main>

    <!-- ===== FOOTER ===== -->
    <footer>
        <div class="footer-wrap">
            <div class="footer-logo">LEMS</div>

            <div class="footer-cols">
                <div class="footer-col">
                    <h4>Features</h4>
                    <a href="/index.php?page=apropos">A propos</a>
                    <a href="/index.php?page=offres">Les offres</a>
                    <a href="/index.php?page=faq">F.A.Q</a>
                </div>

                <div class="footer-col">
                    <h4>Legal</h4>
                    <a href="/index.php?page=mentions-legales">Mentions légales</a>
                    <a href="/index.php?page=conditions-utilisation">Termes d'utilisations</a>
                </div>

                <div class="footer-col">
                    <h4>Socials</h4>
                    <a href="#">Instagram</a>
                    <a href="#">Facebook</a>
                    <a href="#">LinkedIn</a>
                </div>
            </div>
        </div>

        <div class="footer-sep"></div>
        <div class="footer-bottom">
            <span>Copyright © L.E.M.S 2026</span>
        </div>
    </footer>

    {% block javascripts %}
        <script src="/assets/script.js"></script>
    {% endblock %}
</body>
</html>