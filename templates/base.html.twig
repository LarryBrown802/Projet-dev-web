<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/assets/main.css">

    {% block stylesheets %}{% endblock %}

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <title>{% block title %}LEMS{% endblock %}</title>
</head>
<body>
    <header>
        <nav class="navbar">
            <a class="navbar-brand" href="/index.php?page=accueil">LEMS</a>

            <div class="navbar-right">

                {# ===== LIENS COMMUNS À TOUS ===== #}
                <a href="/index.php?page=accueil" class="{% if current_page == 'accueil' %}active{% endif %}">Accueil</a>

                {# ===== LIENS ADMIN ===== #}
                {% if session.role == 'admin' %}
                    <a href="/index.php?page=dashboard_admin"     class="{% if current_page == 'dashboard_admin' %}active{% endif %}">Dashboard</a>
                    <a href="/index.php?page=offer_admin" class="{% if current_page == 'offer_admin' %}active{% endif %}">Gérer offres</a>
                    <a href="/index.php?page=company_admin"  class="{% if current_page == 'company_admin' %}active{% endif %}">Entreprises</a>
                    <a href="/index.php?page=pilot_admin"   class="{% if current_page == 'pilot_admin' %}active{% endif %}">Pilotes</a>
                    <a href="/index.php?page=student_admin"   class="{% if current_page == 'student_admin' %}active{% endif %}">Étudiants</a>

                {# ===== LIENS PILOTE ===== #}
                {% elseif session.role == 'pilote' %}
                    <a href="/index.php?page=dashboard_pilot"     class="{% if current_page == 'dashboard_pilot' %}active{% endif %}">Dashboard</a>
                    <a href="/index.php?page=offer_pilot" class="{% if current_page == 'offer_pilot' %}active{% endif %}">Gérer offres</a>
                    <a href="/index.php?page=company_pilot"  class="{% if current_page == 'company_pilot' %}active{% endif %}">Entreprises</a>
                    <a href="/index.php?page=student_pilot"   class="{% if current_page == 'student_pilot' %}active{% endif %}">Étudiants</a>

                {# ===== LIENS ETUDIANT ===== #}
                {% elseif session.role == 'etudiant' %}
                    <a href="/index.php?page=offers"  class="{% if current_page == 'offers' %}active{% endif %}">Offres</a>
                    <a href="/index.php?page=company" class="{% if current_page == 'company' %}active{% endif %}">Entreprise</a>
                    <a href="/index.php?page=wishlist"  class="{% if current_page == 'wishlist' %}active{% endif %}">Mes Favoris</a>

                {# ===== NON CONNECTÉ ===== #}
                {% else %}
                    <a href="/index.php?page=offers"  class="{% if current_page == 'offers' %}active{% endif %}">Offres</a>
                    <a href="/index.php?page=company" class="{% if current_page == 'company' %}active{% endif %}">Entreprise</a>
                {% endif %}

                {# ===== BOUTON CONNEXION / PROFIL ===== #}
                {% if session.role is not defined or session.role is empty %}
                    <a href="/index.php?page=connexion" class="btn-connexion">Connexion</a>
                {% else %}
                    <div class="profile">
                        <a class="profile-btn" href="/index.php?page=profil" aria-label="Profil">
                            <i class="fa-solid fa-user"></i>
                        </a>

                        <div class="profile-menu" role="menu">
                            <a href="/index.php?page=profil"      role="menuitem">Mon profil</a>
                            <a href="/index.php?page=parametres"  role="menuitem">Paramètres</a>
                            <hr>
                            <a href="/index.php?page=logout" role="menuitem" class="deco">Déconnexion</a>
                        </div>
                    </div>
                {% endif %}

            </div>
        </nav>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer>
        <div class="footer-wrap">
            <div class="footer-logo">LEMS</div>

            <div class="footer-cols">
                <div class="footer-col">
                    <h4>Features</h4>
                    <a href="/index.php?page=apropos">A propos</a>
                    <a href="/index.php?page=offres">Les offres</a>
                    <a href="/index.php?page=faq">F.A.Q</a>
                </div>

                <div class="footer-col">
                    <h4>Legal</h4>
                    <a href="/index.php?page=mentions-legales">Mentions légales</a>
                    <a href="/index.php?page=conditions-utilisation">Termes d'utilisations</a>
                </div>

                <div class="footer-col">
                    <h4>Socials</h4>
                    <a href="#">Instagram</a>
                    <a href="#">Facebook</a>
                    <a href="#">LinkedIn</a>
                </div>
            </div>
        </div>

        <div class="footer-sep"></div>
        <div class="footer-bottom">
            <span>Copyright © L.E.M.S 2026</span>
        </div>
    </footer>

    {% block javascripts %}
        <script src="/assets/script.js"></script>
    {% endblock %}
</body>
</html>