{# 1. On appelle le squelette de base #}
{% extends 'base.html.twig' %}

{# 2. On définit le titre de l'onglet #}
{% block title %}LEMS - Accueil Administrateur{% endblock %}

{# 3. On ajoute uniquement le CSS spécifique à cette page #}
{% block stylesheets %}
    <link rel="stylesheet" href="/assets/pages/accueil.css">
{% endblock %}

{# 4. On injecte le contenu principal de la page #}
{% block content %}
    <section class="hero">
        <div class="hero-bg">
            <div class="hero-overlay"></div>

            <div class="hero-content">
                <span class="hero-text">Notre job, vous aider</span>
                <span class="hero-text">à choisir le vôtre parmi</span>
                <span class="hero-big">4 offres</span>
            </div>
        </div>

        <form class="hero-search" action="/recherche" method="get">
            <div class="searchbox">
                <div class="searchbox-field">
                    <label for="q">QUOI ?</label>
                    <input id="q" name="q" type="text" placeholder="Métier, entreprise, compétence..." />
                </div>

                <div class="searchbox-divider"></div>

                <div class="searchbox-field">
                    <label for="where">OÙ ?</label>
                    <input id="where" name="where" type="text" placeholder="Ville, département, code postal..." />
                </div>

                <button class="searchbox-btn" type="submit" aria-label="Rechercher">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>
    </section>

    <h2>Dernières offres mise en ligne</h2>

    <section class="offers-grid">
        <aside class="list">
            <div class="list-cards">
                
                {# NOTE POUR TON ÉQUIPE : Plus tard, ces "article" seront générés par une boucle Twig (for offre in offres) #}
                <article class="mini-card">
                    <div class="mini-logo"></div>
                    <div>
                        <p class="mini-title">Entreprise<br>Intitulé du poste</p>
                        <p class="mini-info">
                            <i class="fa-solid fa-paperclip fa-rotate-by" style="--fa-rotate-angle: -45deg;"></i>Stage
                            <i class="fa-solid fa-location-dot"></i>Lieu
                            <i class="fa-solid fa-ranking-star"></i>Niveau
                        </p>
                    </div>

                    <label class="ui-bookmark">
                        <input type="checkbox">
                        <div class="bookmark">
                            <svg viewBox="0 0 32 32">
                                <g><path d="M27 4v27a1 1 0 0 1-1.625.781L16 24.281l-9.375 7.5A1 1 0 0 1 5 31V4a4 4 0 0 1 4-4h14a4 4 0 0 1 4 4z"></path></g>
                            </svg>
                        </div>
                    </label>

                    <div class="separateur"></div>
                    <div class="mini-meta"><span class="pill">5h</span></div>
                </article>

                <article class="mini-card">
                    <div class="mini-logo"></div>
                    <div>
                        <p class="mini-title">Entreprise<br>Intitulé du poste</p>
                        <p class="mini-sub">Stage • Lieu • Niveau</p>
                    </div>

                    <label class="ui-bookmark">
                        <input type="checkbox">
                        <div class="bookmark">
                            <svg viewBox="0 0 32 32">
                                <g><path d="M27 4v27a1 1 0 0 1-1.625.781L16 24.281l-9.375 7.5A1 1 0 0 1 5 31V4a4 4 0 0 1 4-4h14a4 4 0 0 1 4 4z"></path></g>
                            </svg>
                        </div>
                    </label>

                    <div class="separateur"></div>
                    <div class="mini-meta"><span class="pill">1j</span></div>
                </article>

                <article class="mini-card">
                    <div class="mini-logo"></div>
                    <div>
                        <p class="mini-title">Entreprise<br>Intitulé du poste</p>
                        <p class="mini-sub">Stage • Lieu • Niveau</p>
                    </div>

                    <label class="ui-bookmark">
                        <input type="checkbox">
                        <div class="bookmark">
                            <svg viewBox="0 0 32 32">
                                <g><path d="M27 4v27a1 1 0 0 1-1.625.781L16 24.281l-9.375 7.5A1 1 0 0 1 5 31V4a4 4 0 0 1 4-4h14a4 4 0 0 1 4 4z"></path></g>
                            </svg>
                        </div>
                    </label>

                    <div class="separateur"></div>
                    <div class="mini-meta"><span class="pill">2j</span></div>
                </article>

            </div>

            <div class="list-footer">
                <a href="/offres" class="btn-voirplus">Voir plus</a>
            </div>
        </aside>
        
        <article class="detail">
            <div class="detail-head">
                <div class="detail-img"></div>
                <div>
                    <p class="detail-title">Titre de l’entreprise</p>
                    <p class="detail-sub">Intitulé du poste</p>
                </div>
                <label class="ui-bookmark">
                    <input type="checkbox">
                    <div class="bookmark">
                        <svg viewBox="0 0 32 32">
                            <g><path d="M27 4v27a1 1 0 0 1-1.625.781L16 24.281l-9.375 7.5A1 1 0 0 1 5 31V4a4 4 0 0 1 4-4h14a4 4 0 0 1 4 4z"></path></g>
                        </svg>
                    </div>
                </label>
            </div>

            <div class="tags">
                <span class="tag t-yellow">Rouen</span>
                <span class="tag t-red">Stage</span>
                <span class="tag t-purple">11</span>
                <span class="tag t-green">Bac+2</span>
            </div>

            <div class="tabs" role="tablist" aria-label="Détails de l'offre">
                <button class="tab-btn active" type="button" data-tab="desc" role="tab" aria-selected="true">Description</button>
                <button class="tab-btn" type="button" data-tab="company" role="tab" aria-selected="false">Entreprise</button>
            </div>

            <div class="detail-body">
                <div class="tab-content active" id="tab-desc" data-content="desc" role="tabpanel">
                    <p class="section-title">Description du poste</p>
                    <p class="para">Lorem ipsum dolor sit amet, consectetur adipiscing elit...</p>

                    <p class="section-title">Prérequis</p>
                    <p class="para">Lorem ipsum dolor sit amet, consectetur adipiscing elit...</p>
                </div>

                <div class="tab-content" id="tab-company" data-content="company" role="tabpanel" hidden>
                    <p class="section-title">À propos de l’entreprise</p>
                    <p class="para">...infos entreprise...</p>

                    <p class="section-title">Technos / environnement</p>
                    <p class="para">...stack, équipe, etc...</p>
                </div>
            </div>

            <div class="detail-footer">
                <button class="apply-btn" type="button">Postuler</button>
            </div>
        </article>
    </section>

    <div class="faq-title">F.A.Q</div>
    <section class="faq">
        <details>
            <summary>Question numéro 1 ?<span class="plus"></span></summary>
            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed non risus.</p>
        </details>
        <details>
            <summary>Question numéro 2 ?<span class="plus"></span></summary>
            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed non risus.</p>
        </details>
        <details>
            <summary>Question numéro 3 ?<span class="plus"></span></summary>
            <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed non risus.</p>
        </details>
    </section>
{% endblock %}